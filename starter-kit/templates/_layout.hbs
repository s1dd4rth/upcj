<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{title}} — UPCJ Starter Kit</title>
  <link rel="stylesheet" href="kit.css">
</head>
<body>
<article class="page" aria-labelledby="page-title">
  <header class="masthead" role="banner">
    <span>UPCJ Starter Kit</span>
    <span class="masthead__tag">{{pageCode}}</span>
  </header>
  <div class="context-band">
    <span>{{contextLeft}}</span>
    <span>{{contextRight}}</span>
  </div>
  {{{body}}}
  <footer class="foot" role="contentinfo">
    <span>UPCJ/SK/{{pageCode}}/EN v{{version}}</span>
    <span>{{pageNumber}} / {{totalPages}}</span>
  </footer>
</article>
</body>
</html>
