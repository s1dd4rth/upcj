{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://upcj.org/spec/v1/schemas/lifecycle.schema.json",
  "title": "Lifecycle",
  "type": "object",
  "required": ["object", "initial", "states"],
  "properties": {
    "object":  { "type": "string", "minLength": 1 },
    "initial": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "states": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "properties": {
            "meta": {
              "type": "object",
              "properties": {
                "step": { "type": "string" }
              }
            },
            "on": {
              "type": "object",
              "patternProperties": {
                "^[a-z][a-z0-9-]*$": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9-]*$"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
